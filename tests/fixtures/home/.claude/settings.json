{
  "env": {
    "FOO": "bar",
    "BAZ": "qux"
  },
  "permissions": {
    "allow": ["Bash(npm run test)", "Read(*)"],
    "deny": ["Bash(rm -rf *)"],
    "ask": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": "./guard.sh" }]
      }
    ],
    "Stop": [
      {
        "hooks": [{ "type": "command", "command": "notify-send done" }]
      }
    ]
  }
}
